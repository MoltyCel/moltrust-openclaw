{
  "name": "@moltrust/openclaw",
  "version": "2.0.0-alpha.0",
  "description": "MolTrust v2 trust-provider plugin for OpenClaw — lifecycle hooks for install / tool-call / inbound / gateway-start gating, plus W3C DID identity verification, trust scoring, sybil detection.",
  "keywords": [
    "openclaw",
    "moltrust",
    "did",
    "verifiable-credentials",
    "agent-trust",
    "trust-provider",
    "sybil-detection",
    "x402"
  ],
  "homepage": "https://moltrust.ch",
  "repository": {
    "type": "git",
    "url": "https://github.com/MoltyCel/moltrust-openclaw"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
